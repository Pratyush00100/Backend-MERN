<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= home.user_name %> | Details</title>
    <link rel="stylesheet" href="/output.css" />
  </head>
  <body class="bg-gray-50 font-sans text-gray-900">
    <%- include('../partials/nav.ejs') %>

    <!-- Main Content -->
    <div class="max-w-6xl mx-auto px-4 py-12">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Left Section -->
        <div class="lg:col-span-2 space-y-6">
          <!-- Image -->
          <div class="rounded-lg overflow-hidden shadow-md">
            <img
              src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&q=80&w=1200"
              alt="<%= home.user_name %>"
              class="w-full h-80 object-cover"
            />
          </div>

          <!-- Header Info -->
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <div class="flex items-start justify-between gap-4 mb-3">
              <div>
                <h1 class="text-3xl font-bold mb-2"><%= home.user_name %></h1>
                <div class="flex items-center gap-3 text-gray-600 text-sm">
                  <div class="flex items-center gap-1">
                    <svg
                      class="w-4 h-4 text-yellow-400"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                      ></path>
                    </svg>
                    <span class="font-semibold"><%= home.rating %>.0</span>
                  </div>
                  <span>•</span>
                  <span><%= home.location %></span>
                </div>
              </div>
              <a
                href="<%= home.link %>"
                target="_blank"
                class="text-rose-600 hover:text-rose-700 font-semibold text-sm whitespace-nowrap"
              >
                View on Airbnb →
              </a>
            </div>
          </div>

          <!-- Description -->
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h2 class="text-lg font-bold mb-2">About this home</h2>
            <p class="text-gray-700 leading-relaxed text-sm">
              Beautiful modern home with stunning views, perfect for families
              and groups. Fully equipped with all amenities for a comfortable
              stay.
            </p>
          </div>
        </div>

        <!-- Right Section - Booking Card -->
        <div class="lg:col-span-1">
          <div
            class="sticky top-32 bg-white rounded-lg border border-gray-200 shadow-lg p-6 space-y-4"
          >
            <!-- Price -->
            <div class="border-b pb-4">
              <div class="flex items-baseline gap-2">
                <span class="text-3xl font-bold">$<%= home.price %></span>
                <span class="text-gray-600 text-sm">/night</span>
              </div>
            </div>

            <!-- Price Breakdown -->
            <div class="space-y-3 text-sm border-b pb-4">
              <div class="flex justify-between">
                <span class="text-gray-600">$<%= home.price %> × 5 nights</span>
                <span>$<%= home.price * 5 %></span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">Cleaning fee</span>
                <span>$50</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">Service fee</span>
                <span>$<%= Math.round(home.price * 5 * 0.1) %></span>
              </div>
            </div>

            <!-- Total -->
            <div class="flex justify-between font-bold text-lg pb-4">
              <span>Total</span>
              <span
                >$<%= home.price * 5 + 50 + Math.round(home.price * 5 * 0.1)
                %></span
              >
            </div>

            <!-- Buttons -->
            <button
              class="w-full bg-rose-600 text-white font-bold py-2 rounded-lg hover:bg-rose-700 transition text-sm"
            >
              Reserve
            </button>
            <a
              href="<%= home.link %>"
              target="_blank"
              class="block w-full bg-gray-100 text-gray-900 font-bold py-2 rounded-lg hover:bg-gray-200 transition text-center text-sm"
            >
              View on Airbnb
            </a>
            <%- include('../partials/fav.ejs') %>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
