<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= editing? "Edit" : "Register"%> Your Home to Airbnb</title>
    <link rel="stylesheet" href="/output.css" />
  </head>
  <body
    class="flex flex-col items-center min-h-screen bg-gray-50 text-gray-900 font-sans"
  >
    <%- include('../partials/nav.ejs') %>
    <div
      class="w-full max-w-md bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden"
    >
      <header class="px-8 pt-8 pb-4 text-center">
        <h1 class="text-3xl font-bold tracking-tight text-gray-900 mb-2">
          <%= editing? "Edit" : "Register"%> Your Home
        </h1>
        <p class="text-sm text-gray-500">
          Enter your property details to get started.
        </p>
      </header>

      <main class="px-8 pb-8">
        <form
          action="/host/<%= editing ? 'edit-home' : 'add-home' %>"
          method="POST"
          class="space-y-5"
          enctype="multipart/form-data"
        >
          <input type="hidden" name="id" value="<%= editing? home._id:''%>" />
          <div>
            <label
              for="name"
              class="block text-sm font-medium text-gray-700 mb-1.5"
            >
              Home Name
            </label>
            <input
              type="text"
              id="name"
              value="<%= editing? home.user_name:''%>"
              name="user_name"
              placeholder="e.g. Cozy Cabin in the Woods"
              required
              class="block w-full px-4 py-3 rounded-xl border border-gray-300 bg-white text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-shadow duration-200 sm:text-sm"
            />
          </div>

          <div>
            <label
              for="location"
              class="block text-sm font-medium text-gray-700 mb-1.5"
            >
              Location
            </label>
            <input
              type="text"
              id="location"
              value="<%= editing? home.location:''%>"
              name="location"
              placeholder="e.g. Aspen, Colorado"
              required
              class="block w-full px-4 py-3 rounded-xl border border-gray-300 bg-white text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-shadow duration-200 sm:text-sm"
            />
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label
                for="price"
                class="block text-sm font-medium text-gray-700 mb-1.5"
              >
                Price per Night
              </label>
              <div class="relative">
                <div
                  class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"
                >
                  <span class="text-gray-500 sm:text-sm">$</span>
                </div>
                <input
                  type="number"
                  id="price"
                  name="price"
                  value="<%= editing? home.price:''%>"
                  placeholder="150"
                  min="0"
                  required
                  class="block w-full pl-7 pr-4 py-3 rounded-xl border border-gray-300 bg-white text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-shadow duration-200 sm:text-sm"
                />
              </div>
            </div>

            <div>
              <label
                for="rating"
                class="block text-sm font-medium text-gray-700 mb-1.5"
              >
                Rating
              </label>
              <input
                type="number"
                id="rating"
                value="<%= editing? home.rating:''%>"
                name="rating"
                placeholder="e.g. 4.8"
                step="0.1"
                min="0"
                max="5"
                class="block w-full px-4 py-3 rounded-xl border border-gray-300 bg-white text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-shadow duration-200 sm:text-sm"
              />
            </div>
            <div>
              <label
                for="Description"
                class="block text-sm font-medium text-gray-700 mb-1.5"
              >
                Description
              </label>
              <textarea
                type="text"
                id="description"
                name="description"
                placeholder="Describe your home"
                step="0.1"
                min="0"
                max="5"
                class="block w-full px-4 py-3 rounded-xl border border-gray-300 bg-white text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-shadow duration-200 sm:text-sm"
              >
                <%= editing? home.description:''%></textarea
              >
            </div>
          </div>

          <div>
            <label
              for="link"
              class="block text-sm font-medium text-gray-700 mb-1.5"
            >
              Listing Link
            </label>
            <input
              type="file"
              id="link"
              name="link"
              accept="image/jpg , image/jpeg ,image/png"
              class="block w-full px-4 py-3 rounded-xl border border-gray-300 bg-white text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-shadow duration-200 sm:text-sm"
            />
          </div>

          <button
            type="submit"
            class="w-full flex justify-center items-center px-6 py-3.5 mt-2 bg-emerald-600 text-white rounded-xl text-base font-semibold shadow-sm hover:bg-emerald-700 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500 transition-all duration-200"
          >
            <%= editing?"Update":"Register"%>
          </button>
        </form>
      </main>
    </div>
  </body>
</html>
