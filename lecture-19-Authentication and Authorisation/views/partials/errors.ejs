 <% if (errors && errors.length > 0) { %>
        <div class="mb-6 rounded-2xl border border-red-200 bg-red-50 p-4">
          <div class="flex items-start gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-red-100 text-red-700 font-bold">!</span>
            <div>
              <p class="text-sm font-semibold text-red-800">Please fix the following:</p>
              <ul class="mt-3 space-y-2 text-sm text-red-700 list-disc list-inside">
                <% errors.forEach(err => { %>
                <li><%= typeof err === 'string' ? err : err.msg %></li>
                <% }) %>
              </ul>
            </div>
          </div>
        </div>
        <% } %>